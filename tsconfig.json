{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "declarationMap": true,

    "strict": true,
    "strictFunctionTypes": false, // 关闭以避免事件处理器类型问题
    "strictPropertyInitialization": false, // NestJS/TypeORM 装饰器模式需要关闭
    "noImplicitThis": true,
    "noUnusedLocals": false, // 开发阶段可以暂时关闭，避免干扰
    "noUnusedParameters": false, // 开发阶段可以暂时关闭，避免干扰
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": false,
    "preserveWatchOutput": true
  }
}
